{
  "name": "@attn-credit/sdk",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "homepage": "https://github.com/twentyOne2x/attn-credit-sdk",
  "bugs": {
    "url": "https://github.com/twentyOne2x/attn-credit-sdk/issues"
  },
  "keywords": [
    "attn",
    "credit",
    "sdk",
    "partner-managed",
    "creator-fees"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./settlement": {
      "types": "./dist/settlement.d.ts",
      "default": "./dist/settlement.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "default": "./dist/schema.js"
    },
    "./eip8183": {
      "types": "./dist/eip8183.d.ts",
      "default": "./dist/eip8183.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts src/schema.ts src/eip8183.ts src/settlement.ts --format cjs --dts --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/twentyOne2x/attn-credit-sdk.git",
    "directory": "packages/sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "zod": "4.3.6"
  }
}
