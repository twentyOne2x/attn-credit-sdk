{
  "name": "@attn-credit/partner-managed-harness-cli",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "attn-partner-harness": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsup src/index.ts --format cjs --dts --sourcemap",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/twentyOne2x/attn-credit-sdk.git",
    "directory": "packages/harness-cli"
  },
  "dependencies": {
    "@attn-credit/clawpump": "workspace:*",
    "@attn-credit/sdk": "workspace:*"
  }
}
