{
  "name": "attn-credit-sdk",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "harness:help": "node packages/harness-cli/dist/index.js --help",
    "harness:clawpump-mock-pilot": "node packages/harness-cli/dist/index.js clawpump-mock-pilot",
    "harness:clawpump-mock-matrix": "node packages/harness-cli/dist/index.js clawpump-mock-matrix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm build && pnpm exec tsx --test tests/sdk-client.test.ts tests/clawpump-client.test.ts tests/harness-cli.test.ts"
  },
  "devDependencies": {
    "@types/node": "20.19.32",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "zod": "4.3.6"
  }
}
